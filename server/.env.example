# ============================================
# AI Code Review Assistant — Environment Config
# ============================================

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL / Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/ai_code_review?schema=public"

# JWT Secrets (min 32 characters each — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET="CHANGE_ME_your_jwt_secret_at_least_32_chars"
JWT_REFRESH_SECRET="CHANGE_ME_your_refresh_secret_at_least_32_chars"

# JWT Expiry
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Groq API (LLM)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Frontend URL (CORS whitelist)
CLIENT_URL="http://localhost:5173"
